---
interface PortfolioItem {
  title: string;
  location?: string;
  image: string;
  alt: string;
}

interface Props {
  items: PortfolioItem[];
}

const { items } = Astro.props;
---

<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
  {items.map((item) => (
    <article class="group">
      <div class="relative overflow-hidden rounded-2xl">
        <img class="aspect-[4/5] w-full rounded-2xl object-cover transition duration-500 group-hover:scale-105" src={item.image} alt={item.alt} loading="lazy" />
        <span class="absolute left-1/2 top-1/2 hidden -translate-x-1/2 -translate-y-1/2 bg-ink text-cream font-mono text-xs tracking-[0.06em] uppercase px-6 py-3 rounded-[10px] group-hover:block">
          View
        </span>
      </div>
      <div class="mt-5 flex items-start justify-between gap-6 border-t border-ink pt-4">
        <h2 class="text-xl font-medium leading-tight">{item.title}</h2>
        {item.location && <p class="font-mono text-xs tracking-[0.04em] uppercase opacity-60">{item.location}</p>}
      </div>
    </article>
  ))}
</div>
