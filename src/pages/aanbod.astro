---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import zweetkamertje2 from '../assets/portfolio/zweetkamertje-2.jpg';
import kleinKind from '../assets/portfolio/klein-kind.jpg';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Promotiefotografie Radboud Universiteit',
  description:
    "Vast pakket voor de fotografie van een promotie aan de Radboud Universiteit Nijmegen: 3 uur aanwezigheid, 130 rechtenvrije foto's binnen 1 week.",
  provider: {
    '@type': 'Person',
    name: 'Paul Breuker',
    email: 'info@paulbreuker.nl',
    telephone: '+31651475406',
  },
  areaServed: {
    '@type': 'City',
    name: 'Nijmegen',
  },
  offers: {
    '@type': 'AggregateOffer',
    lowPrice: '270',
    highPrice: '326.70',
    priceCurrency: 'EUR',
    availability: 'https://schema.org/InStock',
    offerCount: 2,
  },
};

const timelineItems = [
  {
    time: '45 minuten voor aanvang',
    title: 'Cella Sudatoria',
    description:
      "Ik neem je mee naar het zweetkamertje. Daar zet je je handtekening op de muur en maak ik portretten van jou en je paranimfen.",
  },
  {
    time: 'Voor en tijdens de verdediging',
    title: 'Pedel en verdediging',
    description:
      'Daarna volgen de instructies van de pedel en de verdediging zelf. Ik ken de regels rond beweging, geluid en timing.',
  },
  {
    time: 'Hora est',
    title: 'Diploma en bul',
    description:
      "Na 'hora est' leg ik de handtekeningen van rector en promotoren vast. Als vaste fotograaf mag ik ook foto's maken van het ondertekenen van het diploma.",
  },
  {
    time: 'Op de trap',
    title: 'Groepsfoto corona',
    description:
      'Op weg naar de felicitaties maken we een groepsfoto van de voltallige corona samen met jou en je paranimfen.',
  },
  {
    time: 'Na de verdediging',
    title: 'Felicitaties',
    description:
      "Daarna is er ruimte voor foto's met familie, vrienden en promotoren. Ik help om dat rustig te laten verlopen.",
  },
];
---

<BaseLayout
  title="Aanbod & Tarief | Fotograaf Promotie Radboud"
  description="Promotiefotografie Radboud Universiteit: vast pakket vanaf €270. 3 uur fotografie, 130 rechtenvrije foto's, levering binnen 1 week. Bekijk het volledige aanbod."
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <!-- SECTIE 1: PAGE HEADER -->
  <section class="pt-16 md:pt-24 pb-16 md:pb-24">
    <div class="max-w-[1440px] mx-auto px-6 md:px-16">
      <p class="font-mono text-xs tracking-[0.04em] uppercase opacity-60 mb-12">
        Aanbod
      </p>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-12 md:gap-16 items-end">
        <h1 class="md:col-span-8 text-5xl md:text-6xl lg:text-7xl font-medium leading-[1.05]">
          Helder geprijsd.
        </h1>
        <p class="md:col-span-4 text-[17px] text-ink/70 leading-relaxed md:pb-3">
          Geen pakketmatrix. Een helder aanbod voor de verdediging, felicitaties en receptie.
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[1440px] px-6 pb-24 md:px-16 md:pb-32">
    <div class="overflow-hidden rounded-2xl">
      <Image
        src={zweetkamertje2}
        alt="Promovendus en paranimfen in het zweetkamertje vlak voor de verdediging aan de Radboud Universiteit"
        class="h-full w-full aspect-[16/10] rounded-2xl object-cover"
        widths={[800, 1200, 1600]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>

  <!-- SECTIE 2: HET PAKKET -->
  <section class="border-t border-ink py-24 md:py-32">
    <div class="mx-auto max-w-[1440px] px-6 md:px-16">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-12 md:gap-16">
        <div class="md:col-span-7">
          <p class="mb-12 font-mono text-xs tracking-[0.04em] uppercase opacity-60">
            Wat je krijgt
          </p>

          <ul class="border-t border-ink/20">
            <li class="flex gap-8 items-start py-8 border-b border-ink/20">
              <span class="w-9 h-9 border border-ink rounded-full flex items-center justify-center font-mono text-[11px] tracking-[0.06em] flex-shrink-0">
                01
              </span>
              <div class="flex-1">
                <p class="text-xl md:text-2xl font-medium leading-tight">3 uur aanwezigheid</p>
                <p class="mt-3 text-[15px] text-ink/70 leading-relaxed max-w-md">
                  Vanaf 45 minuten voor aanvang van de verdediging tot en met de receptie.
                </p>
              </div>
            </li>

            <li class="flex gap-8 items-start py-8 border-b border-ink/20">
              <span class="w-9 h-9 border border-ink rounded-full flex items-center justify-center font-mono text-[11px] tracking-[0.06em] flex-shrink-0">
                02
              </span>
              <div class="flex-1">
                <p class="text-xl md:text-2xl font-medium leading-tight">
                  Volledige promotiedag vastgelegd
                </p>
                <p class="mt-3 text-[15px] text-ink/70 leading-relaxed max-w-md">
                  Cella Sudatoria, instructies van de pedel, verdediging, hora est, bul,
                  groepsfoto, felicitaties en receptie.
                </p>
              </div>
            </li>

            <li class="flex gap-8 items-start py-8 border-b border-ink/20">
              <span class="w-9 h-9 border border-ink rounded-full flex items-center justify-center font-mono text-[11px] tracking-[0.06em] flex-shrink-0">
                03
              </span>
              <div class="flex-1">
                <p class="text-xl md:text-2xl font-medium leading-tight">
                  130 zorgvuldig geselecteerde foto's
                </p>
                <p class="mt-3 text-[15px] text-ink/70 leading-relaxed max-w-md">
                  Ik maak een selectie en bewerk de foto's op kleur en contrast. De foto's worden
                  rechtenvrij geleverd.
                </p>
              </div>
            </li>

            <li class="flex gap-8 items-start py-8 border-b border-ink/20">
              <span class="w-9 h-9 border border-ink rounded-full flex items-center justify-center font-mono text-[11px] tracking-[0.06em] flex-shrink-0">
                04
              </span>
              <div class="flex-1">
                <p class="text-xl md:text-2xl font-medium leading-tight">
                  Levering in kleur
                </p>
                <p class="mt-3 text-[15px] text-ink/70 leading-relaxed max-w-md">
                  Standaard in kleur. Zwart-wit is mogelijk tegen €50 meerprijs.
                </p>
              </div>
            </li>

            <li class="flex gap-8 items-start py-8 border-b border-ink/20">
              <span class="w-9 h-9 border border-ink rounded-full flex items-center justify-center font-mono text-[11px] tracking-[0.06em] flex-shrink-0">
                05
              </span>
              <div class="flex-1">
                <p class="text-xl md:text-2xl font-medium leading-tight">
                  Levering via WeTransfer
                </p>
                <p class="mt-3 text-[15px] text-ink/70 leading-relaxed max-w-md">
                  Je ontvangt de foto's in hoge resolutie via WeTransfer.
                </p>
              </div>
            </li>

            <li class="flex gap-8 items-start py-8 border-b border-ink/20">
              <span class="w-9 h-9 border border-ink rounded-full flex items-center justify-center font-mono text-[11px] tracking-[0.06em] flex-shrink-0">
                06
              </span>
              <div class="flex-1">
                <p class="text-xl md:text-2xl font-medium leading-tight">
                  Twee betaalopties
                </p>
                <p class="mt-3 text-[15px] text-ink/70 leading-relaxed max-w-md">
                  €270 contant na de receptie. Of €326,70 incl. btw via factuur, per mail na
                  ontvangst van de foto's.
                </p>
              </div>
            </li>
          </ul>
        </div>

        <aside class="md:col-span-5 md:sticky md:top-32 md:self-start">
          <p class="mb-8 font-mono text-xs tracking-[0.04em] uppercase opacity-60">
            Investering
          </p>

          <p class="text-6xl md:text-7xl font-medium leading-none">€270</p>

          <p class="mt-4 text-[15px] text-ink/70">
            Contant na de receptie. Of €326,70 incl. btw via factuur, per mail na ontvangst van de
            foto's.
          </p>

          <div class="border-t border-ink/20 my-10"></div>

          <a
            href="/contact"
            class="inline-block bg-ink text-cream font-mono text-xs tracking-[0.06em] uppercase px-8 py-4 rounded-[10px] hover:opacity-90 transition"
          >
            Vraag beschikbaarheid aan
          </a>

          <p class="mt-6 font-mono text-[11px] tracking-[0.04em] uppercase opacity-50">
            Geen aanbetaling
          </p>
        </aside>
      </div>
    </div>
  </section>

  <!-- SECTIE 3: HOE VERLOOPT DE DAG -->
  <section class="mx-auto max-w-[1440px] px-6 py-24 md:px-16 md:py-32">
    <div class="grid gap-10 border-t border-ink pt-10 lg:grid-cols-[0.35fr_0.65fr]">
      <p class="font-mono text-xs tracking-[0.04em] uppercase opacity-60">De dag zelf</p>
      <div>
        <h2 class="max-w-4xl text-3xl md:text-4xl lg:text-5xl font-medium leading-[1.05] uppercase break-words">
          Een typische promotie, in fasen
        </h2>
        <p class="mt-8 max-w-2xl text-[17px] leading-[1.55]">
          Geen promotie is hetzelfde, maar het ritueel is vertrouwd. Hieronder zie je hoe ik je door
          de dag meeneem.
        </p>
      </div>
    </div>
    <ol class="mt-16 grid border-y border-ink md:grid-cols-5 md:divide-x md:divide-accent-red">
      {
        timelineItems.map((item, index) => (
          <li class="py-8 md:px-6 lg:px-8">
            <span class="grid h-9 w-9 place-items-center rounded-full border border-ink font-mono text-[11px] tracking-[0.06em]">
              {String(index + 1).padStart(2, '0')}
            </span>
            <p class="mt-8 font-mono text-xs tracking-[0.04em] uppercase opacity-60">{item.time}</p>
            <h3 class="mt-3 text-2xl font-medium leading-tight">{item.title}</h3>
            <p class="mt-4 text-[15px] leading-[1.5]">{item.description}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- SECTIE 4: VISUELE PAUZE -->
  <section class="mx-auto max-w-[1440px] px-6 py-24 md:px-16 md:py-32">
    <div class="grid items-end gap-8 border-t border-ink pt-10 md:grid-cols-12">
      <div class="overflow-hidden rounded-2xl md:col-span-7">
        <Image
          src={kleinKind}
          alt="Klein kind aanwezig bij de promotie van een ouder aan de Radboud Universiteit"
          class="h-full w-full aspect-[4/5] rounded-2xl object-cover md:aspect-[4/3]"
          widths={[400, 800, 1200]}
          sizes="(max-width: 768px) 100vw, 60vw"
        />
      </div>
      <div class="md:col-span-5">
        <p class="font-mono text-xs tracking-[0.04em] uppercase opacity-60">Radboud protocol</p>
        <h2 class="mt-6 text-3xl md:text-4xl lg:text-5xl font-medium leading-[1.05] uppercase break-words">
          Rustig aanwezig. Wel betrokken.
        </h2>
        <p class="mt-8 max-w-md text-[17px] leading-[1.55]">
          Tijdens de ceremonie werk ik volgens het Radboud-protocol. Voor en na de verdediging
          begeleid ik je naar de vaste momenten, zodat je weet wat er komt.
        </p>
      </div>
    </div>
  </section>

  <!-- SECTIE 5: LEVERING -->
  <section class="mx-auto max-w-[1440px] px-6 py-24 md:px-16 md:py-32">
    <div class="grid gap-10 border-t border-ink pt-10 lg:grid-cols-[0.35fr_0.65fr]">
      <p class="font-mono text-xs tracking-[0.04em] uppercase opacity-60">Levering</p>
      <div>
        <h2 class="max-w-4xl text-3xl md:text-4xl lg:text-5xl font-medium leading-[1.05] uppercase break-words">
          Binnen 1 week in je inbox
        </h2>
        <div class="mt-8 max-w-3xl space-y-5 text-[17px] leading-[1.55]">
          <p>
            Ik selecteer de foto's zorgvuldig en bewerk ze op kleur en contrast. Binnen 1 week na de
            promotie ontvang je een mail van mij dat de bestanden onderweg zijn via WeTransfer.
          </p>
          <p>
            Je krijgt de foto's in hoge resolutie, geschikt voor afdrukken en digitaal delen.
          </p>
        </div>
        <div class="mt-12 grid border-y border-ink font-mono text-xs tracking-[0.04em] uppercase opacity-60 md:grid-cols-2 md:divide-x md:divide-ink">
          <p class="py-5 md:px-6">Hoge resolutie</p>
          <p class="border-t border-ink py-5 md:border-t-0 md:px-6">Rechtenvrij</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTIE 6: EXTRA MOGELIJK -->
  <section class="mx-auto max-w-[1440px] px-6 py-24 md:px-16 md:py-32">
    <div class="grid gap-10 border-t border-ink pt-10 lg:grid-cols-[0.35fr_0.65fr]">
      <p class="font-mono text-xs tracking-[0.04em] uppercase opacity-60">Extra mogelijk</p>
      <div>
        <h2 class="max-w-4xl text-3xl md:text-4xl lg:text-5xl font-medium leading-[1.05] uppercase break-words">
          Voor na de promotie
        </h2>
        <div class="mt-8 max-w-3xl space-y-5 text-[17px] leading-[1.55]">
          <p>
            Wil je ook een feestje of diner laten fotograferen, 's avonds of op een ander moment?
            Dat kan op aanvraag.
          </p>
          <p>
            Afdrukken zijn mogelijk in elk gewenst formaat. Ik kan ook een strak vormgegeven
            fotoboek maken, in diverse formaten.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTIE 7: SLOT CTA -->
  <section class="mx-auto max-w-[1440px] px-6 py-24 md:px-16 md:py-32">
    <div class="border-y border-ink py-16 text-center md:py-20">
      <p class="font-mono text-xs tracking-[0.04em] uppercase opacity-60">Beschikbaarheid</p>
      <h2 class="mx-auto mt-8 max-w-4xl text-3xl md:text-4xl lg:text-5xl font-medium leading-[1.05] uppercase break-words">
        Klaar om je datum vast te leggen?
      </h2>
      <p class="mx-auto mt-8 max-w-xl text-[17px] leading-[1.55]">
        Stuur me de details van je promotie. Binnen 4 werkdagen reactie.
      </p>
      <a
        href="/contact"
        class="mt-10 inline-block bg-ink text-cream font-mono text-xs tracking-[0.06em] uppercase px-6 py-3 rounded-[10px] hover:bg-accent-red-dark transition-colors duration-200"
      >
        Vraag beschikbaarheid aan
      </a>
    </div>
  </section>

</BaseLayout>
