---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import foto2 from '../assets/portfolio/foto-2.jpg';
import foto4 from '../assets/portfolio/foto-4.jpg';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Promotiefotografie Radboud Universiteit',
  description:
    "Vast pakket voor de fotografie van een promotie aan de Radboud Universiteit Nijmegen: 2 uur aanwezigheid, 100 nabewerkte foto's.",
  provider: {
    '@type': 'Person',
    name: 'Paul Breuker',
    email: 'info@paulbreuker.nl',
    telephone: '+31651475406',
  },
  areaServed: {
    '@type': 'City',
    name: 'Nijmegen',
  },
  offers: {
    '@type': 'Offer',
    price: '300',
    priceCurrency: 'EUR',
    availability: 'https://schema.org/InStock',
    validFrom: '2025-01-01',
  },
};

const timelineItems = [
  {
    time: '30 minuten voor aanvang',
    title: 'In het zweetkamertje',
    description:
      'Een korte begroeting, geen lange instructies. Ik leg de spanning, de paranimfen, de ouders en de eerste rituelen vast.',
  },
  {
    time: 'Aanvang verdediging',
    title: 'De ceremonie',
    description:
      'Binnenkomst van de pedel, het lekenpraatje, de oppositie, vragen vanuit de commissie. Ik beweeg ingetogen door de zaal en let op het protocol.',
  },
  {
    time: 'Hora est',
    title: 'Het moment',
    description:
      'Het belangrijkste signaal van de dag. De pedel klopt af, de commissie trekt zich terug. Ik leg de reactie van promovendus en familie vast.',
  },
  {
    time: 'Uitreiking bul',
    title: 'Laudatio en ondertekening',
    description:
      'Het toespraakje van de promotor, het ondertekenen van de bul, de eerste handdruk. Klassieke momenten die elke promovendus terugziet.',
  },
  {
    time: 'Eerste felicitaties',
    title: "Familie en collega's",
    description:
      "De spontane omhelzingen, het bloemenboeket, de groepsfoto's met paranimfen en familie. Hier eindigt het pakket.",
  },
];
---

<BaseLayout
  title="Aanbod & Tarief | Fotograaf Promotie Radboud"
  description="Het pakket kost €300, alles inbegrepen. 2 uur fotografie op je promotiedag, 100 nabewerkte foto's, levering binnen 2 weken."
  alternateUrl="https://fotograafpromotieradboud.nl/en/services/"
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <!-- SECTIE 1: PAGE HEADER -->
  <section class="pt-16 md:pt-24 pb-16 md:pb-24">
    <div class="max-w-[1440px] mx-auto px-6 md:px-16">
      <p class="font-mono text-xs tracking-[0.04em] uppercase opacity-60 mb-12">
        Aanbod
      </p>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-12 md:gap-16 items-end">
        <h1 class="md:col-span-8 text-5xl md:text-6xl lg:text-7xl font-medium leading-[1.05]">
          Helder geprijsd.
        </h1>
        <p class="md:col-span-4 text-[17px] text-ink/70 leading-relaxed md:pb-3">
          Geen pakketmatrix, geen meerprijsjes voor extra foto's. Een simpel aanbod waarvan ik weet
          dat het voor de meeste promoties precies past.
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[1440px] px-6 pb-24 md:px-16 md:pb-32">
    <div class="overflow-hidden rounded-2xl">
      <Image
        src={foto2}
        alt="Promovendus tijdens de verdediging aan de Radboud Universiteit"
        class="h-full w-full aspect-[16/10] rounded-2xl object-cover"
        widths={[800, 1200, 1600]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>

  <!-- SECTIE 2: HET PAKKET -->
  <section class="border-t border-ink py-24 md:py-32">
    <div class="mx-auto max-w-[1440px] px-6 md:px-16">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-12 md:gap-16 items-start">
        <div class="md:col-span-7">
          <p class="mb-12 font-mono text-xs tracking-[0.04em] uppercase opacity-60">
            Wat je krijgt
          </p>

          <ul class="border-t border-ink/20">
            <li class="flex gap-8 items-start py-8 border-b border-ink/20">
              <span class="w-9 h-9 border border-ink rounded-full flex items-center justify-center font-mono text-[11px] tracking-[0.06em] flex-shrink-0">
                01
              </span>
              <div class="flex-1">
                <p class="text-xl md:text-2xl font-medium leading-tight">2 uur aanwezigheid</p>
                <p class="mt-3 text-[15px] text-ink/70 leading-relaxed max-w-md">
                  Vanaf circa 30 minuten voor aanvang van de verdediging tot na de eerste
                  felicitaties.
                </p>
              </div>
            </li>

            <li class="flex gap-8 items-start py-8 border-b border-ink/20">
              <span class="w-9 h-9 border border-ink rounded-full flex items-center justify-center font-mono text-[11px] tracking-[0.06em] flex-shrink-0">
                02
              </span>
              <div class="flex-1">
                <p class="text-xl md:text-2xl font-medium leading-tight">
                  Volledige ceremonie vastgelegd
                </p>
                <p class="mt-3 text-[15px] text-ink/70 leading-relaxed max-w-md">
                  Voorbereidingen in het zweetkamertje, de verdediging, hora est, de uitreiking van
                  de bul, en de eerste felicitaties.
                </p>
              </div>
            </li>

            <li class="flex gap-8 items-start py-8 border-b border-ink/20">
              <span class="w-9 h-9 border border-ink rounded-full flex items-center justify-center font-mono text-[11px] tracking-[0.06em] flex-shrink-0">
                03
              </span>
              <div class="flex-1">
                <p class="text-xl md:text-2xl font-medium leading-tight">
                  100 zorgvuldig geselecteerde foto's
                </p>
                <p class="mt-3 text-[15px] text-ink/70 leading-relaxed max-w-md">
                  Uit de honderden opnames selecteer en bewerk ik er honderd. Geen volledige
                  bulkdrop.
                </p>
              </div>
            </li>

            <li class="flex gap-8 items-start py-8 border-b border-ink/20">
              <span class="w-9 h-9 border border-ink rounded-full flex items-center justify-center font-mono text-[11px] tracking-[0.06em] flex-shrink-0">
                04
              </span>
              <div class="flex-1">
                <p class="text-xl md:text-2xl font-medium leading-tight">
                  Levering in kleur en zwart-wit
                </p>
                <p class="mt-3 text-[15px] text-ink/70 leading-relaxed max-w-md">
                  Beide versies in hoge resolutie, geschikt voor afdrukken en digitaal delen.
                </p>
              </div>
            </li>

            <li class="flex gap-8 items-start py-8 border-b border-ink/20">
              <span class="w-9 h-9 border border-ink rounded-full flex items-center justify-center font-mono text-[11px] tracking-[0.06em] flex-shrink-0">
                05
              </span>
              <div class="flex-1">
                <p class="text-xl md:text-2xl font-medium leading-tight">
                  Persoonlijke online galerij
                </p>
                <p class="mt-3 text-[15px] text-ink/70 leading-relaxed max-w-md">
                  Eigen pagina met wachtwoord. Foto's te downloaden in hoge en lage resolutie.
                </p>
              </div>
            </li>

            <li class="flex gap-8 items-start py-8 border-b border-ink/20">
              <span class="w-9 h-9 border border-ink rounded-full flex items-center justify-center font-mono text-[11px] tracking-[0.06em] flex-shrink-0">
                06
              </span>
              <div class="flex-1">
                <p class="text-xl md:text-2xl font-medium leading-tight">
                  Reiskosten & BTW inbegrepen
                </p>
                <p class="mt-3 text-[15px] text-ink/70 leading-relaxed max-w-md">
                  Reiskosten binnen Nijmegen zitten in het pakket. De prijs die je ziet is de prijs
                  die je betaalt.
                </p>
              </div>
            </li>
          </ul>
        </div>

        <div class="md:col-span-5">
          <div class="md:sticky md:top-32">
            <p class="mb-8 font-mono text-xs tracking-[0.04em] uppercase opacity-60">
              Investering
            </p>

            <p class="text-6xl md:text-7xl font-medium leading-none">€300</p>

            <p class="mt-4 text-[15px] text-ink/70">Het pakket. Alles inbegrepen.</p>

            <div class="border-t border-ink/20 my-10"></div>

            <a
              href="/contact"
              class="inline-block bg-ink text-cream font-mono text-xs tracking-[0.06em] uppercase px-8 py-4 rounded-[10px] hover:opacity-90 transition"
            >
              Vraag beschikbaarheid aan
            </a>

            <p class="mt-6 font-mono text-[11px] tracking-[0.04em] uppercase opacity-50">
              Geen aanbetaling — betaling na levering
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTIE 3: HOE VERLOOPT DE DAG -->
  <section class="mx-auto max-w-[1440px] px-6 py-24 md:px-16 md:py-32">
    <div class="grid gap-10 border-t border-ink pt-10 lg:grid-cols-[0.35fr_0.65fr]">
      <p class="font-mono text-xs tracking-[0.04em] uppercase opacity-60">De dag zelf</p>
      <div>
        <h2 class="max-w-4xl text-3xl md:text-4xl lg:text-5xl font-medium leading-[1.05] uppercase break-words">
          Een typische promotie, in fasen
        </h2>
        <p class="mt-8 max-w-2xl text-[17px] leading-[1.55]">
          Geen promotie is hetzelfde, maar de structuur is dat wel. Hieronder hoe een doorsnee dag
          eruitziet en wanneer ik welke momenten vastleg.
        </p>
      </div>
    </div>
    <ol class="mt-16 grid border-y border-ink md:grid-cols-5 md:divide-x md:divide-ink">
      {
        timelineItems.map((item, index) => (
          <li class="py-8 md:px-6 lg:px-8">
            <span class="grid h-9 w-9 place-items-center rounded-full border border-ink font-mono text-[11px] tracking-[0.06em]">
              {String(index + 1).padStart(2, '0')}
            </span>
            <p class="mt-8 font-mono text-xs tracking-[0.04em] uppercase opacity-60">{item.time}</p>
            <h3 class="mt-3 text-2xl font-medium leading-tight">{item.title}</h3>
            <p class="mt-4 text-[15px] leading-[1.5]">{item.description}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- SECTIE 4: VISUELE PAUZE -->
  <section class="mx-auto max-w-[1440px] px-6 py-24 md:px-16 md:py-32">
    <div class="grid items-end gap-8 border-t border-ink pt-10 md:grid-cols-12">
      <div class="overflow-hidden rounded-2xl md:col-span-7">
        <Image
          src={foto4}
          alt="Promotieceremonie aan de Radboud Universiteit, moment na uitreiking bul"
          class="h-full w-full aspect-[4/5] rounded-2xl object-cover md:aspect-[4/3]"
          widths={[400, 800, 1200]}
          sizes="(max-width: 768px) 100vw, 60vw"
        />
      </div>
      <div class="md:col-span-5">
        <p class="font-mono text-xs tracking-[0.04em] uppercase opacity-60">Radboud protocol</p>
        <h2 class="mt-6 text-3xl md:text-4xl lg:text-5xl font-medium leading-[1.05] uppercase break-words">
          Rustig aanwezig. Niets forceren.
        </h2>
        <p class="mt-8 max-w-md text-[17px] leading-[1.55]">
          Tijdens de ceremonie werk ik ingetogen door de zaal. De pedel, de commissie en het
          verloop van de verdediging krijgen altijd voorrang.
        </p>
      </div>
    </div>
  </section>

  <!-- SECTIE 5: LEVERING -->
  <section class="mx-auto max-w-[1440px] px-6 py-24 md:px-16 md:py-32">
    <div class="grid gap-10 border-t border-ink pt-10 lg:grid-cols-[0.35fr_0.65fr]">
      <p class="font-mono text-xs tracking-[0.04em] uppercase opacity-60">Levering</p>
      <div>
        <h2 class="max-w-4xl text-3xl md:text-4xl lg:text-5xl font-medium leading-[1.05] uppercase break-words">
          Binnen twee weken in je inbox
        </h2>
        <div class="mt-8 max-w-3xl space-y-5 text-[17px] leading-[1.55]">
          <p>
            Ik werk niet met spoedlevering of hoge meerprijs voor 'rush jobs'. Iedere promovendus
            krijgt dezelfde behandeling: zorgvuldige selectie, consistente nabewerking, levering
            binnen twee weken na de promotiedatum.
          </p>
          <p>
            Je ontvangt een link naar een persoonlijke online galerij, beveiligd met een
            wachtwoord. Daar staan alle foto's in hoge en lage resolutie, gegroepeerd per fase van
            de dag. Familie en vrienden kun je toegang geven door simpelweg de link te delen.
          </p>
        </div>
        <div class="mt-12 grid border-y border-ink font-mono text-xs tracking-[0.04em] uppercase opacity-60 md:grid-cols-3 md:divide-x md:divide-ink">
          <p class="py-5 md:px-6">Hoge resolutie</p>
          <p class="border-t border-ink py-5 md:border-t-0 md:px-6">Lage resolutie</p>
          <p class="border-t border-ink py-5 md:border-t-0 md:px-6">Wachtwoordgalerij</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTIE 6: SLOT CTA -->
  <section class="mx-auto max-w-[1440px] px-6 py-24 md:px-16 md:py-32">
    <div class="border-y border-ink py-16 text-center md:py-20">
      <p class="font-mono text-xs tracking-[0.04em] uppercase opacity-60">Beschikbaarheid</p>
      <h2 class="mx-auto mt-8 max-w-4xl text-3xl md:text-4xl lg:text-5xl font-medium leading-[1.05] uppercase break-words">
        Klaar om je datum vast te leggen?
      </h2>
      <p class="mx-auto mt-8 max-w-xl text-[17px] leading-[1.55]">
        Stuur me de details van je promotie. Ik bevestig binnen vierentwintig uur of de datum nog
        beschikbaar is.
      </p>
      <a
        href="/contact"
        class="mt-10 inline-block bg-ink text-cream font-mono text-xs tracking-[0.06em] uppercase px-6 py-3 rounded-[10px] hover:opacity-90 transition"
      >
        Vraag beschikbaarheid aan
      </a>
    </div>
  </section>
</BaseLayout>
