---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import zweetkamertjeHero from '../assets/portfolio/zweetkamertje-hero.jpg';
import zweetkamertje from '../assets/portfolio/zweetkamertje.jpg';
import knuffel from '../assets/portfolio/knuffel.jpg';
import shotje from '../assets/portfolio/shotje.jpg';
import voorbereiding from '../assets/portfolio/voorbereiding.jpg';

interface FaqItem {
  question: string;
  answer: string;
}

const faqItems: FaqItem[] = [
  {
    question: 'Hoe lang ben je aanwezig op de promotiedag?',
    answer: '3 uur, vanaf 45 minuten voor aanvang van de verdediging tot en met de receptie.',
  },
  {
    question: "Wanneer ontvang ik de foto's?",
    answer:
      "Binnen 1 week. Je ontvangt een mail van mij zodra de foto's via WeTransfer onderweg zijn.",
  },
  {
    question: "Hoeveel foto's krijg ik?",
    answer:
      "Rond de 130 zorgvuldig geselecteerde foto's, standaard in kleur. Zwart-wit kan tegen €50 meerprijs.",
  },
  {
    question: 'Mag je in de Aula fotograferen tijdens de verdediging?',
    answer:
      "Ja. Ik ken het Radboud-protocol. Als vaste fotograaf mag ik ook foto's maken van het ondertekenen van het diploma.",
  },
  {
    question: 'Hoe ver van tevoren kan ik boeken?',
    answer: 'Liefst twee tot zes maanden vooraf. Populaire data zijn vroeg vergeven.',
  },
  {
    question: 'Wat gebeurt er als mijn promotie verplaatst wordt?',
    answer: 'Geen probleem. Ik plan kosteloos met je om naar de nieuwe datum.',
  },
  {
    question: 'Wat kost het?',
    answer:
      "€270 bij contante betaling na de receptie. Of €326,70 incl. btw via factuur, per mail na ontvangst van de foto's.",
  },
  {
    question: "Maak je ook foto's van de receptie of het diner?",
    answer:
      "Ja. De receptie zit in het pakket. Feestjes en diners 's avonds of op een ander moment zijn op aanvraag mogelijk.",
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title="Promotiefotograaf Radboud Nijmegen | Vanaf €270"
  description="Professionele promotiefotograaf aan de Radboud Universiteit Nijmegen. 3 uur aanwezig t/m receptie, 130 rechtenvrije foto's binnen 1 week. Vanaf €270. Check beschikbaarheid."
  image="/og-home.jpg"
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- // SECTIE 1: HERO -->
  <section class="mx-auto max-w-[1440px] px-6 py-24 md:px-16 md:py-32">
    <span aria-hidden="true" class="mb-6 block h-[3px] w-12 bg-accent-red"></span>
    <p class="font-mono text-xs tracking-[0.04em] uppercase opacity-60 mb-12">
      Promotiefotografie · Radboud Universiteit Nijmegen
    </p>
    <div class="grid grid-cols-1 gap-8 md:grid-cols-12 md:gap-16 items-end">
      <h1 class="md:col-span-8 text-5xl md:text-6xl lg:text-7xl font-medium leading-[1.05]">
        De fotograaf voor je promotie.
      </h1>
      <p class="md:col-span-4 text-[17px] leading-[1.55] md:pb-3">
        Ik begeleid je rustig door de dag en leg de vaste momenten zorgvuldig vast.
      </p>
    </div>
    <div class="mt-12 overflow-hidden rounded-2xl">
      <Image
        src={zweetkamertjeHero}
        alt="Promovenda zet haar handtekening op de muur van de Cella Sudatoria van de Radboud Universiteit"
        class="h-full w-full aspect-[16/10] rounded-2xl object-cover"
        widths={[800, 1200, 1920, 2400]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>

  <!-- // SECTIE 2: STATEMENT -->
  <section class="mx-auto max-w-[1440px] px-6 py-24 md:px-16 md:py-32">
    <div class="grid gap-10 border-t border-ink pt-10 lg:grid-cols-[0.35fr_0.65fr]">
      <p class="font-mono text-xs tracking-[0.04em] uppercase opacity-60">Specialisme</p>
      <div>
        <h2 class="max-w-4xl text-3xl md:text-4xl lg:text-5xl font-medium leading-[1.05] uppercase break-words">
        Fotografie van Radboud promoties, oraties en afscheidsrede's.
        </h2>
        <p class="mt-8 max-w-3xl text-[17px] leading-[1.55]">
        Een promotie laat zich niet overdoen. De handtekening in de Cella Sudatoria, het moment van
        'hora est', de groepsfoto op de trap en de receptie volgen elkaar snel op. Ik ken dat ritueel
        en neem je er rustig doorheen.
        </p>
      </div>
    </div>
  </section>

  <!-- // SECTIE 3: PORTFOLIO TEASER -->
  <section class="mx-auto max-w-[1440px] px-6 py-24 md:px-16 md:py-32">
    <div class="grid gap-10 border-t border-ink pt-10 lg:grid-cols-[0.35fr_0.65fr]">
      <p class="font-mono text-xs tracking-[0.04em] uppercase opacity-60">Eerder werk</p>
      <h2 class="max-w-4xl text-3xl md:text-4xl lg:text-5xl font-medium leading-[1.05] uppercase break-words">
        Een selectie uit recente promoties
      </h2>
    </div>
    <div class="mt-16 grid grid-cols-2 gap-3 md:grid-cols-12 md:gap-8">
        <div class="col-span-1 aspect-[4/5] overflow-hidden rounded-2xl md:aspect-auto md:col-span-7 md:row-span-2">
          <Image
            src={zweetkamertje}
            alt="Promovendus in het zweetkamertje vlak voor de verdediging aan de Radboud Universiteit"
            class="h-full w-full aspect-[4/5] rounded-2xl object-cover transition duration-700 hover:scale-105 md:aspect-auto"
            widths={[400, 800, 1200]}
            sizes="(max-width: 768px) 100vw, 50vw"
          />
        </div>
        <div class="col-span-1 aspect-[4/5] overflow-hidden rounded-2xl md:aspect-auto md:col-span-5">
          <Image
            src={knuffel}
            alt="Eerste omhelzing na de uitreiking van de bul in het Academiegebouw Nijmegen"
            class="h-full w-full aspect-[4/5] rounded-2xl object-cover transition duration-700 hover:scale-105 md:aspect-auto"
            widths={[400, 800, 1200]}
            sizes="(max-width: 768px) 100vw, 50vw"
          />
        </div>
        <div class="col-span-2 aspect-[3/2] overflow-hidden rounded-2xl md:aspect-auto md:col-span-5">
          <Image
            src={shotje}
            alt="Promovendus en collega's heffen het glas na een geslaagde promotie aan de Radboud"
            class="h-full w-full aspect-[4/5] rounded-2xl object-cover transition duration-700 hover:scale-105 md:aspect-auto"
            widths={[400, 800, 1200]}
            sizes="(max-width: 768px) 100vw, 50vw"
          />
        </div>
      </div>
      <div class="mt-12">
        <a
          href="/contact"
          class="inline-block border border-ink text-ink font-mono text-xs tracking-[0.06em] uppercase px-6 py-3 rounded-[10px] hover:bg-accent-red-dark hover:text-cream hover:border-accent-red-dark transition-colors duration-200"
        >
          Vraag beschikbaarheid aan
        </a>
      </div>
  </section>

  <!-- // SECTIE 4: KORTE INTRODUCTIE -->
  <section class="border-t border-accent-red py-16 md:py-24">
    <div class="max-w-[1440px] mx-auto px-6 md:px-16">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16 items-center">
        <div class="md:col-span-5 order-1">
          <p class="font-mono text-xs tracking-[0.04em] uppercase opacity-60">Over mij</p>
          <h2 class="mt-6 text-2xl md:text-4xl lg:text-5xl font-medium leading-[1.1] uppercase break-words">
            Een fotograaf die het ritueel kent.
          </h2>
          <div class="mt-8 space-y-5">
            <p class="text-[15px] md:text-[17px] leading-relaxed">
              Ik fotografeer promoties aan de Radboud Universiteit met aandacht voor rust, timing
              en duidelijke begeleiding. Veel promovendi ervaren dat als prettig op een drukke dag.
            </p>
            <p class="text-[15px] md:text-[17px] leading-relaxed">
              Na honderden promoties gefotografeerd te hebben, ken ik het ritueel en begeleid ik je
              door de dag heen.
            </p>
          </div>
          <a
            href="/over"
            class="mt-8 inline-block border-b border-ink font-mono text-xs tracking-[0.06em] uppercase transition hover:opacity-60"
          >
            Lees meer <span aria-hidden="true" class="text-accent-red">→</span>
          </a>
        </div>
        <div class="md:col-span-7 order-2">
          <Image
            src={voorbereiding}
            alt="Stil moment van voorbereiding voor de promotieceremonie in het Academiegebouw van de Radboud"
            class="w-full aspect-[3/2] object-cover rounded-2xl"
            widths={[400, 800]}
            sizes="(max-width: 768px) 100vw, 50vw"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- // SECTIE 5: HOE HET WERKT -->
  <section class="mx-auto max-w-[1440px] px-6 py-24 md:px-16 md:py-32">
    <div class="grid gap-10 border-t border-ink pt-10 lg:grid-cols-[0.35fr_0.65fr]">
      <p class="font-mono text-xs tracking-[0.04em] uppercase opacity-60">Het proces</p>
      <h2 class="max-w-4xl text-3xl md:text-4xl lg:text-5xl font-medium leading-[1.05] uppercase break-words">
        Van eerste contact tot levering
      </h2>
    </div>
      <ol class="mt-16 grid border-y border-ink md:grid-cols-4 md:divide-x md:divide-accent-red">
        <li class="py-8 md:px-8">
          <span class="grid h-9 w-9 place-items-center rounded-full border border-ink font-mono text-[11px] tracking-[0.06em]">01</span>
          <h3 class="mt-8 text-2xl font-medium uppercase leading-tight break-words">Aanvraag</h3>
          <p class="mt-4 text-[15px] leading-[1.5]">
            Een korte mailwisseling om datum, locatie en eventuele wensen af te stemmen. Geen
            verplicht gesprek vooraf.
          </p>
        </li>
        <li class="py-8 md:px-8">
          <span class="grid h-9 w-9 place-items-center rounded-full border border-ink font-mono text-[11px] tracking-[0.06em]">02</span>
          <h3 class="mt-8 text-2xl font-medium uppercase leading-tight break-words">Bevestiging</h3>
          <p class="mt-4 text-[15px] leading-[1.5]">
            Datum vast, details afgestemd. Geen aanbetaling vooraf.
          </p>
        </li>
        <li class="py-8 md:px-8">
          <span class="grid h-9 w-9 place-items-center rounded-full border border-ink font-mono text-[11px] tracking-[0.06em]">03</span>
          <h3 class="mt-8 text-2xl font-medium uppercase leading-tight break-words">De dag zelf</h3>
          <p class="mt-4 text-[15px] leading-[1.5]">
            Ik ben 45 minuten voor aanvang aanwezig en werk 3 uur door, van Cella Sudatoria tot en
            met de receptie.
          </p>
        </li>
        <li class="py-8 md:px-8">
          <span class="grid h-9 w-9 place-items-center rounded-full border border-ink font-mono text-[11px] tracking-[0.06em]">04</span>
          <h3 class="mt-8 text-2xl font-medium uppercase leading-tight break-words">Levering</h3>
          <p class="mt-4 text-[15px] leading-[1.5]">
            Binnen 1 week ontvang je rond de 130 zorgvuldig geselecteerde foto's via WeTransfer,
            in hoge resolutie.
          </p>
        </li>
      </ol>
  </section>

  <!-- // SECTIE 7: INVESTERING -->
  <section class="mx-auto max-w-[1440px] px-6 py-24 md:px-16 md:py-32">
    <div class="grid gap-10 border-t border-ink pt-10 lg:grid-cols-[0.35fr_0.65fr]">
      <p class="font-mono text-xs tracking-[0.04em] uppercase opacity-60">Investering</p>
      <div>
        <h2 class="max-w-4xl text-3xl md:text-4xl lg:text-5xl font-medium leading-[1.05] uppercase break-words">
        Het pakket. Helder geprijsd.
        </h2>
        <p class="mt-8 max-w-2xl text-[17px] leading-[1.55]">
        Ik werk met een vast aanbod, zodat je vooraf precies weet wat je krijgt. 3 uur aanwezigheid
        op je promotiedag, rond de 130 rechtenvrije foto's in kleur, geleverd binnen 1 week via
        WeTransfer. Zwart-wit is mogelijk tegen €50 meerprijs.
        </p>
        <div class="mt-10 inline-flex flex-wrap items-baseline gap-3 border-y border-ink py-6 pr-6 md:pr-12">
          <span class="text-5xl font-medium leading-none tracking-[-0.02em]">€270</span>
          <span class="font-mono text-xs tracking-[0.04em] uppercase opacity-60">contant na receptie · €326,70 incl. btw via factuur</span>
        </div>
        <a
          href="/aanbod"
          class="mt-10 block w-fit border-b border-ink font-mono text-xs tracking-[0.06em] uppercase transition hover:opacity-60"
        >
          Bekijk het volledige aanbod
        </a>
      </div>
    </div>
  </section>

  <!-- // SECTIE 8: FAQ -->
  <section class="mx-auto max-w-[1440px] px-6 py-24 md:px-16 md:py-32">
    <div class="grid gap-10 border-t border-ink pt-10 lg:grid-cols-[0.35fr_0.65fr]">
      <p class="font-mono text-xs tracking-[0.04em] uppercase opacity-60">Veelgestelde vragen</p>
      <h2 class="max-w-4xl text-3xl md:text-4xl lg:text-5xl font-medium leading-[1.05] uppercase break-words">
        Goed om vooraf te weten
      </h2>
    </div>
      <div class="mt-16 divide-y divide-ink border-y border-ink">
        {
          faqItems.map((item) => (
            <details class="group">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-8 py-6 text-xl font-medium transition hover:opacity-60 md:text-2xl">
                {item.question}
                <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full border border-ink font-mono text-[13px] transition-[transform,color,border-color] duration-200 group-open:rotate-45 group-open:border-accent-red group-open:text-accent-red">
                  +
                </span>
              </summary>
              <p class="max-w-3xl pb-6 text-[17px] leading-[1.55]">{item.answer}</p>
            </details>
          ))
        }
      </div>
  </section>

  <!-- // SECTIE 9: SLOT -->
  <section class="mx-auto max-w-[1440px] px-6 py-24 md:px-16 md:py-32">
    <div class="border-y border-ink py-16 text-center">
      <h2 class="mx-auto max-w-4xl text-3xl md:text-4xl lg:text-5xl font-medium leading-[1.05] uppercase break-words">
        Klaar om je datum te reserveren?
      </h2>
      <p class="mx-auto mt-8 max-w-xl text-[17px] leading-[1.55]">
        Vul het aanvraagformulier in. Binnen 4 werkdagen reactie.
      </p>
      <a
        href="/contact"
        class="mt-10 inline-block bg-ink text-cream font-mono text-xs tracking-[0.06em] uppercase px-6 py-3 rounded-[10px] hover:bg-accent-red-dark transition-colors duration-200"
      >
        Vraag beschikbaarheid aan
      </a>
    </div>
  </section>
</BaseLayout>
